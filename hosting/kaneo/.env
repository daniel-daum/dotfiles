# ── General URLs ──────────────────────────────────────────────────
KANEO_CLIENT_URL=
KANEO_API_URL=

# ── Database ──────────────────────────────────────────────────────
# Full connection string — update host to your postgres container name
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ── Authentication ────────────────────────────────────────────────
# Must be ≥32 chars — generate with:  war
AUTH_SECRET=

# ── Access Control (optional) ─────────────────────────────────────
DISABLE_GUEST_ACCESS=
DISABLE_REGISTRATION=

# ── minio (optional) ───────────────────────────────────────────────
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_FORCE_PATH_STYLE=

# ── Github Integration (optional) ───────────────────────────
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_APP_NAME=


# ── Custom OAuth/OIDC (optional) ──────────────────────────────────
CUSTOM_OAUTH_CLIENT_ID=
CUSTOM_OAUTH_CLIENT_SECRET=
CUSTOM_OAUTH_DISCOVERY_URL=
CUSTOM_OAUTH_SCOPES=
CUSTOM_OAUTH_RESPONSE_TYPE=
CUSTOM_AUTH_PKCE=

