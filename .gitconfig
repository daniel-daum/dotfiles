[user]
	name = daniel daum
	email = daniel@danieldaum.net
	signingkey = /Users/daniel/Library/Containers/com.maxgoedjen.Secretive.SecretAgent/Data/PublicKeys/7a42c4933fb6cbb7d73547a75e757882.pub
[push]
	autoSetupRemote = true
[commit]
	gpgsign = true
[gpg]
	format = ssh
[gpg "ssh"]
    allowedSignersFile = ~/.gitallowedsigners
[tag]
	gpgSign = true
[alias]
	# status
	st = status --short --branch

	# add
	a  = add
	ap = add --patch

	# commit
	c  = commit
	cm = commit --message

	# sync
	pl = pull --rebase
	ps = push
	fp = fetch --prune

	# cleanup
	sweep = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
